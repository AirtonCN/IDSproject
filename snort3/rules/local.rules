# local.rules — Reglas personalizadas Snort 3
# La sintaxis de reglas es compatible con Snort 2

# Detecta intentos de conexión SSH
alert tcp any any -> $HOME_NET 22 ( msg:"[Snort3 IDS] SSH Access Attempt"; sid:1000010; rev:1; )

# Detecta escaneo de puertos con nmap (SYN scan)
alert tcp any any -> $HOME_NET any ( msg:"[Snort3 IDS] Port Scan Detected"; flags:S; threshold:type threshold, track by_src, count 20, seconds 3; sid:1000011; rev:1; )

# Detecta ping (ICMP echo request)
alert icmp any any -> $HOME_NET any ( msg:"[Snort3 IDS] ICMP Ping"; itype:8; sid:1000012; rev:1; )
